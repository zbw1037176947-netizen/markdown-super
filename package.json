{
  "name": "markdown-super",
  "displayName": "Markdown Super",
  "description": "All-in-one Markdown preview & editing experience for VS Code — Mermaid, LaTeX, WYSIWYG, and more.",
  "version": "0.0.1",
  "publisher": "adsgo",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownSuper.openPreview",
        "title": "Open Preview",
        "category": "Markdown Super",
        "icon": "$(open-preview)"
      },
      {
        "command": "markdownSuper.openPreviewToSide",
        "title": "Open Preview to the Side",
        "category": "Markdown Super",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "markdownSuper.openPreviewToSide",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markdownSuper.openPreviewToSide",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Super",
      "properties": {
        "markdownSuper.mermaid.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Mermaid diagram rendering"
        },
        "markdownSuper.katex.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable KaTeX math formula rendering"
        },
        "markdownSuper.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Preview theme (auto follows VS Code theme)"
        },
        "markdownSuper.fontSize": {
          "type": "number",
          "default": 16,
          "description": "Preview font size in pixels"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:prod": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "katex": "^0.16.0",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.0",
    "mermaid": "^11.4.0"
  }
}
